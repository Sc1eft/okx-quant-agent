# OKX Quant Agent — 环境变量配置
# 复制本文件为 .env 并填入真实值
# cp .env.example .env  (Mac/Linux)
# copy .env.example .env  (Windows)

# ── OKX 交易所 API ──
# 需在 OKX 创建 API Key：个人中心 → API → 创建
# 权限推荐：仅交易（trade），不开提现权限
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── DeepSeek AI Agent ──
# API Key 从 https://platform.deepseek.com 获取
# 模型默认 deepseek-v4-pro，可通过 config.json 修改
DEEPSEEK_API_KEY=

# ── Phase 3: 链上数据 API（可选） ──

# Etherscan API Key（用于 Gas 费监控）
# 从 https://etherscan.io/myapikey 获取（免费）
ETHERSCAN_API_KEY=

# Whale Alert API Key（用于巨鲸转账监控）
# 从 https://docs.whale-alert.io 获取（免费 15 次/天）
WHALE_ALERT_API_KEY=

# ── 运行模式 ──
# paper | live | demo | backtest
# 可通过 python main.py --mode paper 覆盖
# AGENT_MODE=paper
